# 1. Copy this file and rename it to .env.local
# 2. Змінні для фронтенду (site). LiveKit/S3 налаштовуються в next/.env

# PUBLIC (frontend)
# Uncomment settings menu when using a LiveKit Cloud, it'll enable Krisp noise filters.
NEXT_PUBLIC_SHOW_SETTINGS_MENU=true
# Backend API (окремий сервіс next). Якщо не вказано — очікується той самий origin.
NEXT_PUBLIC_CONN_DETAILS_ENDPOINT=http://localhost:3001/api/connection-details
NEXT_PUBLIC_LK_RECORD_ENDPOINT=http://localhost:3001/api/record
