{
  "name": "livekit-meet",
  "version": "0.2.0",
  "private": true,
  "workspaces": ["site", "next", "run/*"],
  "scripts": {
    "dev": "bun run --cwd site dev",
    "dev:api": "bun run --cwd next dev",
    "build": "bun run --cwd site build",
    "build:api": "bun run --cwd next build",
    "start": "bun run --cwd site start",
    "start:api": "bun run --cwd next start",
    "lint": "bun run --cwd site lint",
    "lint:fix": "bun run --cwd site lint:fix",
    "test": "bun run --cwd site test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "format:write": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "book": "cd book && mdbook serve"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "prettier": "3.7.3"
  },
  "engines": {
    "node": ">=24"
  }
}
